{
  "plugin_id": "continuum.arrouter",
  "version": "1.0.0",
  "checksum": "__CHECKSUM__",
  "continuum_api_version": "v1",
  "category": "Requests",
  "supported_platforms": [
    {
      "os": "linux",
      "arch": "amd64"
    }
  ],
  "capabilities": [
    {
      "type": "event_consumer.v1",
      "id": "router",
      "display_name": "Router",
      "description": "Routes request events to a registered Radarr/Sonarr based on rules.",
      "subscriptions": [
        "plugin.continuum.requests.submitted",
        "plugin.continuum.requests.cancelled"
      ]
    },
    {
      "type": "scheduled_task.v1",
      "id": "poll",
      "display_name": "Poll *arrs",
      "description": "Polls registered *arrs for download/import progress."
    },
    {
      "type": "http_routes.v1",
      "id": "admin",
      "display_name": "Arr Request Router Admin",
      "description": "Admin SPA for the Arr Request Router plugin."
    },
    {
      "type": "request_router.v1",
      "id": "default",
      "display_name": "Rule-based Arr request router",
      "description": "Routes requests to one of N registered Radarr/Sonarr instances based on rules."
    }
  ],
  "http_routes": [
    {
      "id": "api",
      "method": "*",
      "path": "/api/admin/*",
      "access": "admin"
    },
    {
      "id": "assets",
      "method": "GET",
      "path": "/assets/*",
      "access": "public"
    },
    {
      "id": "spa",
      "method": "GET",
      "path": "/admin/*",
      "access": "admin",
      "navigable": true,
      "navigation_label": "Arr Router",
      "navigation_kind": "admin"
    }
  ],
  "global_config_schema": [
    {
      "key": "database_url",
      "title": "Postgres connection string",
      "description": "DSN for the dedicated arrouter schema (e.g. postgres://plugin_arrouter:...@host:5432/continuum?search_path=arrouter&sslmode=disable).",
      "json_schema": "{\"type\":\"object\",\"properties\":{\"value\":{\"type\":\"string\"}},\"required\":[\"value\"]}",
      "required": true,
      "admin_form": {
        "fields": [
          {
            "key": "value",
            "label": "Connection URL",
            "control": "ADMIN_FORM_CONTROL_PASSWORD",
            "required": true,
            "secret": true
          }
        ]
      }
    }
  ]
}
