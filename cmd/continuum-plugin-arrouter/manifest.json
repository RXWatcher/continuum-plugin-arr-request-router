{
  "plugin_id": "continuum.arrouter",
  "version": "0.1.0",
  "checksum": "__CHECKSUM__",
  "continuum_api_version": "v1",
  "capabilities": [
    {
      "type": "event_consumer.v1",
      "id": "router",
      "display_name": "Router",
      "description": "Routes request events to a registered Radarr/Sonarr based on rules.",
      "subscriptions": [
        "plugin.continuum.requests.submitted",
        "plugin.continuum.requests.cancelled"
      ]
    },
    {
      "type": "scheduled_task.v1",
      "id": "poll",
      "display_name": "Poll *arrs",
      "description": "Polls registered *arrs for download/import progress."
    },
    {
      "type": "http_routes.v1",
      "id": "admin",
      "display_name": "Arrouter Admin",
      "description": "Admin SPA for the arrouter plugin."
    }
  ],
  "http_routes": [
    {"id": "api",    "method": "*",   "path": "/api/admin/*", "access": "admin"},
    {"id": "assets", "method": "GET", "path": "/assets/*",    "access": "admin"},
    {"id": "spa",    "method": "GET", "path": "/admin*",      "access": "admin", "navigable": true, "navigation_label": "Arrouter", "navigation_kind": "admin"}
  ],
  "global_config_schema": [
    {
      "key": "database_url",
      "title": "Postgres connection string",
      "description": "DSN for the dedicated arrouter schema (e.g. postgres://plugin_arrouter:...@host:5432/continuum?search_path=arrouter&sslmode=disable).",
      "json_schema": "{\"type\":\"object\",\"properties\":{\"value\":{\"type\":\"string\"}},\"required\":[\"value\"]}",
      "required": true,
      "admin_form": {
        "fields": [
          {
            "key": "value",
            "label": "Connection URL",
            "control": "ADMIN_FORM_CONTROL_PASSWORD",
            "required": true,
            "secret": true
          }
        ]
      }
    },
    {
      "key": "tmdb.api_key",
      "title": "TMDB API key",
      "description": "TMDB v3 API key. Used for rule enrichment (genres, keywords, content rating, etc.).",
      "json_schema": "{\"type\":\"object\",\"properties\":{\"value\":{\"type\":\"string\"}},\"required\":[\"value\"]}",
      "required": true,
      "admin_form": {
        "fields": [
          {
            "key": "value",
            "label": "API Key",
            "control": "ADMIN_FORM_CONTROL_PASSWORD",
            "required": true,
            "secret": true
          }
        ]
      }
    },
    {
      "key": "tmdb.language",
      "title": "TMDB language",
      "description": "TMDB language query param for enrichment lookups. Defaults to en-US.",
      "json_schema": "{\"type\":\"object\",\"properties\":{\"value\":{\"type\":\"string\"}}}",
      "admin_form": {
        "fields": [
          {
            "key": "value",
            "label": "Language (e.g. en-US)",
            "control": "ADMIN_FORM_CONTROL_TEXT"
          }
        ]
      }
    },
    {
      "key": "poll_interval_seconds",
      "title": "Poll interval (seconds)",
      "description": "How often the poll loop checks each registered *arr. Minimum 10, maximum 600. Defaults to 30.",
      "json_schema": "{\"type\":\"object\",\"properties\":{\"value\":{\"type\":\"integer\",\"minimum\":10,\"maximum\":600}}}",
      "admin_form": {
        "fields": [
          {
            "key": "value",
            "label": "Poll interval (seconds, 10–600)",
            "control": "ADMIN_FORM_CONTROL_NUMBER"
          }
        ]
      }
    },
    {
      "key": "stale_after_hours",
      "title": "Stale after (hours)",
      "description": "Mark requests stuck in submitted/downloading as failed after this many hours. Defaults to 72.",
      "json_schema": "{\"type\":\"object\",\"properties\":{\"value\":{\"type\":\"integer\",\"minimum\":1}}}",
      "admin_form": {
        "fields": [
          {
            "key": "value",
            "label": "Mark failed after (hours)",
            "control": "ADMIN_FORM_CONTROL_NUMBER"
          }
        ]
      }
    },
    {
      "key": "secret_key",
      "title": "Secret encryption key",
      "description": "Symmetric key (any non-empty string) used to encrypt registered_arr.api_key at rest. Rotating this key invalidates all stored API keys.",
      "json_schema": "{\"type\":\"object\",\"properties\":{\"value\":{\"type\":\"string\",\"minLength\":16}},\"required\":[\"value\"]}",
      "required": true,
      "admin_form": {
        "fields": [
          {
            "key": "value",
            "label": "Encryption key (min 16 chars)",
            "control": "ADMIN_FORM_CONTROL_PASSWORD",
            "required": true,
            "secret": true
          }
        ]
      }
    }
  ]
}
